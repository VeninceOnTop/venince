local Players = game:GetService("Players")
local player = Players.LocalPlayer

local LINK = 'loadstring(game:HttpGet("https://api.jnkie.com/api/v1/luascripts/public/a2f8d2180eb124393fbdcdae0e68f6fbcd8e82c197bc555a487d195e9d8f8e86/download"))()'

-- GUI
local gui = Instance.new("ScreenGui")
gui.Name = "LinkGui"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

-- Fundo
local frame = Instance.new("Frame")
frame.Parent = gui
frame.Size = UDim2.fromScale(0.8, 0.25)
frame.Position = UDim2.fromScale(0.1, 0.35)
frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
frame.BorderSizePixel = 0
frame.AnchorPoint = Vector2.new(0, 0)
frame.ClipsDescendants = true
frame.Name = "MainFrame"

local corner = Instance.new("UICorner", frame)
corner.CornerRadius = UDim.new(0, 16)

-- Texto copiável
local textBox = Instance.new("TextBox")
textBox.Parent = frame
textBox.Size = UDim2.fromScale(0.95, 0.6)
textBox.Position = UDim2.fromScale(0.025, 0.15)
textBox.Text = LINK
textBox.TextWrapped = true
textBox.TextScaled = true
textBox.ClearTextOnFocus = false
textBox.MultiLine = true
textBox.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
textBox.TextColor3 = Color3.fromRGB(255, 255, 255)
textBox.Font = Enum.Font.Code
textBox.BorderSizePixel = 0
textBox.Name = "LinkBox"

local boxCorner = Instance.new("UICorner", textBox)
boxCorner.CornerRadius = UDim.new(0, 12)

-- Botão copiar
local button = Instance.new("TextButton")
button.Parent = frame
button.Size = UDim2.fromScale(0.4, 0.18)
button.Position = UDim2.fromScale(0.3, 0.8)
button.Text = "COPIAR LINK"
button.BackgroundColor3 = Color3.fromRGB(60, 130, 255)
button.TextColor3 = Color3.fromRGB(255, 255, 255)
button.Font = Enum.Font.GothamBold
button.TextScaled = true
button.BorderSizePixel = 0

local btnCorner = Instance.new("UICorner", button)
btnCorner.CornerRadius = UDim.new(0, 12)

-- Ação de copiar
button.MouseButton1Click:Connect(function()
	-- Método avançado (funciona em executores)
	if setclipboard then
		setclipboard(LINK)
		button.Text = "COPIADO!"
	else
		-- Fallback universal (manual)
		textBox:CaptureFocus()
		textBox.SelectionStart = 1
		textBox.CursorPosition = #LINK + 1
		button.Text = "SELECIONADO"
	end
	
	task.delay(1.5, function()
		button.Text = "COPIAR LINK"
	end)
end)
